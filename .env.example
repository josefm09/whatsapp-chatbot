# Example Environment Variables

# Port to run the server
PORT=3000

# WhatsApp Business Cloud API (recomendado para México)
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=
WHATSAPP_API_VERSION=v17.0

# Django/DB
SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=*
# Para Railway Postgres, se inyecta DATABASE_URL automáticamente; de forma local puedes usar:
# DATABASE_URL=sqlite:///db.sqlite3

# Clinic schedule configuration
# Opening hour (24h)
OPEN_HOUR=9
# Closing hour (24h)
CLOSE_HOUR=17
# Slot size in minutes
SLOT_MINUTES=60
# How many days ahead users can book
MAX_DAYS_AHEAD=30
